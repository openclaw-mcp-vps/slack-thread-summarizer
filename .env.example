# Public app URL used for OAuth callback and metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe Payment Link configuration
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_XXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXX
STRIPE_WEBHOOK_SECRET=whsec_XXX

# Required for verifying checkout sessions and webhook signatures
STRIPE_SECRET_KEY=sk_test_XXX

# Slack OAuth + Events API
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_SCOPES=app_mentions:read,channels:history,chat:write,groups:history,im:history,mpim:history

# OpenAI summarization
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional: override secret used to sign paid-access cookie
PAYWALL_COOKIE_SECRET=
